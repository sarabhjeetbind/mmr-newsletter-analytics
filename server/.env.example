# ── MMR Newsletter Analytics proxy ─────────────────────────────
# Copy to `.env` and fill in. NEVER commit .env (add it to .gitignore).

# Set to true to serve bundled sample data with NO credentials (great for a first run).
MOCK=true

# Azure AD service principal (Fabric admin creates this — see server/README.md)
TENANT_ID=00000000-0000-0000-0000-000000000000
CLIENT_ID=00000000-0000-0000-0000-000000000000
CLIENT_SECRET=your-service-principal-secret

# Power BI / Fabric workspace + semantic model (dataset) GUIDs
WORKSPACE_ID=00000000-0000-0000-0000-000000000000
DATASET_ID=00000000-0000-0000-0000-000000000000

# Server
PORT=8787
CACHE_MINUTES=10
